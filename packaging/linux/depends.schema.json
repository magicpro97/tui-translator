{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/magicpro97/tui-translator/blob/main/packaging/linux/depends.schema.json",
  "title": "tui-translator Linux runtime dependency manifest",
  "type": "object",
  "required": ["version", "targets", "runtime_libraries", "preflight"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "targets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["package_format", "required", "install_hint"],
        "properties": {
          "package_format": { "type": "string", "enum": ["deb", "rpm", "appimage", "flatpak"] },
          "required":   { "type": "array", "items": { "type": "string" } },
          "recommends": { "type": "array", "items": { "type": "string" } },
          "suggests":   { "type": "array", "items": { "type": "string" } },
          "install_hint": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "runtime_libraries": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["soname", "tier", "purpose", "missing_remediation"],
        "properties": {
          "soname": { "type": "string", "pattern": "^lib.+\\.so(\\.[0-9]+)*$" },
          "tier": { "type": "integer", "minimum": 0, "maximum": 3 },
          "purpose": { "type": "string" },
          "missing_remediation": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "preflight": {
      "type": "object",
      "required": ["minimum_required_libraries", "minimum_required_runtime_one_of", "failure_action", "log_field"],
      "properties": {
        "minimum_required_libraries": { "type": "array", "items": { "type": "string" } },
        "minimum_required_runtime_one_of": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "failure_action": { "type": "string", "enum": ["exit_with_remediation", "warn_and_continue"] },
        "log_field": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
