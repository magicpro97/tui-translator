# Rust build output
/target/

# Cargo lock is kept for binaries (reproducible builds)
# Remove this line if you want to ignore it for library crates.
# Cargo.lock

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Environment / secrets — NEVER commit API keys
.env
.env.*
config.json
.copilot-state/
.octogent/

# config.example.json IS committed (no real keys in it)

# Test / coverage artifacts
coverage/
*.profraw
*.profdata
lcov.info

# Soak runner reports - generated at runtime; not committed
verification-evidence/*.json
verification-evidence/*.txt
verification-evidence/hot-config/*.json

# Exceptions: planning inputs that w0-r1 / w0-r6 evidence and the
# `build-wave-plan.js` driver explicitly reference by path.  These are
# generated artefacts but their checked-in form is required for the
# evidence chain to be reproducible from a fresh checkout (the script
# fails fast otherwise and the w0-r1 / w0-r6 `commands.md` logs would be
# untrue).  Keep them tracked even though the generic *.json rule above
# would otherwise exclude them.
!verification-evidence/board-snapshot-20260524.json
!verification-evidence/family-file-map.json
!verification-evidence/wave-plan.json

# Release artifacts
*.exe
*.zip
*.tar.gz

# WBS-08 privacy artifacts
# Real session transcript logs - utterances, costs, speaker text.
# Default storage: %APPDATA%\tui-translator\sessions\ (outside the repo).
# Ignored here in case the binary is run from the project root, or an eval
# script writes a sessions/ directory relative to cwd.
sessions/
*.session.jsonl

# Raw audio archive - WAV recording of all speakers in the meeting.
# Default storage: %APPDATA%\tui-translator\audio-archive\ (outside the repo).
# NOTE: global *.wav is intentionally NOT added - committed test fixtures under
# tests/ (tests/fixtures/*.wav, tests/soak/soak_audio.wav) must remain visible.
# Stage new test WAV files with `git add -f` if they are rejected by commit-gate.
audio-archive/

# Eval-session measurement report directories (WBS load / accuracy evaluation runs).
# target/ at line 2 already covers target/eval-session/; this rule also catches
# an eval-session/ directory placed at the project root by evaluation scripts.
eval-session/

scripts/standards/**/__pycache__/

*.orig\n*.rej
src/audio/mod.rs.orig
src/audio/mod.rs.rej
verification-evidence/
